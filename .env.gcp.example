# Public hostname pointing to your GCP VM.
NAKAMA_DOMAIN=nakama.your-domain.com

# Optional node name for the running Nakama instance.
NAKAMA_NODE_NAME=nakama-gcp-1

# Replace these with long random strings before deployment.
NAKAMA_SERVER_KEY=replace-with-a-long-random-server-key
NAKAMA_HTTP_KEY=replace-with-a-long-random-http-key

# Console credentials. Access the console through SSH tunneling only.
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=replace-with-a-strong-console-password
